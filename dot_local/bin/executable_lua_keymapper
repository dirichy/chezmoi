#!/usr/bin/env lua
---@class SHELL
---@field cmd string

local SHELL = {}
SHELL.__index = SHELL
function SHELL.new(cmd)
	local res = { cmd = cmd }
	return setmetatable(res, SHELL)
end
---@type fun(a:SHELL,b:SHELL):SHELL
function SHELL.__bor(a, b)
	return SHELL.new("(" .. a.cmd .. ") || (" .. b.cmd .. ")")
end
---@type fun(a:SHELL,b:SHELL):SHELL
function SHELL.__band(a, b)
	return SHELL.new("(" .. a.cmd .. ") && (" .. b.cmd .. ")")
end
---@type fun(a:SHELL,b:SHELL):SHELL
function SHELL.__add(a, b)
	return SHELL.new("(" .. a.cmd .. ") ; (" .. b.cmd .. ")")
end
function SHELL:karabiner()
	return { shell_command = self.cmd }
end

local karabiner = {}
local keyd = {}
local aerospace = {}
local hyprland = {}
local M = { karabiner = karabiner, keyd = keyd, aerospace = aerospace, hyprland = hyprland }
-- SHIFT CAPS CTRL/CONTROL ALT MOD2 MOD3 SUPER/WIN/LOGO/MOD4 MOD5
---@alias lua_keymapper.mod "SHIFT"|"CTRL"|"ALT"|"SUPER"
---@class lua_keymapper.processor
---@field fn function
---@field condition fun():boolean
---@field priority number
---@class lua_keymapper.table
---@field [string] lua_keymapper.processor[]

M.modifier = {
	SHIFT = 1,
	CTRL = 2,
	ALT = 4,
	SUPER = 8,
	FN = 16,
}
local SHIFT = 1
local CTRL = 2
local ALT = 4
local SUPER = 8
local FN = 16

local function mod2int(mods)
	if not mods then
		return 0
	end
	if type(mods) == "number" then
		return mods
	end
	local ret = 0
	if type(mods) == "string" then
		mods = { mods }
	end
	for index, value in ipairs(mods) do
		local mod = M.modifier[value]
		if not mod then
			error("unknown modifier: " .. value)
			break
		end
		ret = ret + mod
	end
	return ret
end
--For karabiner
---@class Karabiner.json.to
---@field shell_command string?
---@field key_code string?
---@field modifiers (table<number,string>)?
---@alias Karabiner.to string|table|SHELL
karabiner.modifier = {
	shift = 1,
	control = 2,
	command = 4,
	option = 8,
	fn = 16,
}
karabiner.vitualMod = {}
karabiner._next_vitual_mod_value = 32

local JSON = require("cjson")
karabiner.condition = {
	always = function()
		return JSON.empty_array
	end,
	not_moonlight = function()
		return karabiner.condition.application_unless("^com\\.moonlight-stream\\.Moonlight$")
	end,
	application = function(applications)
		if type(applications) == "string" then
			applications = { applications }
		end
		return { {
			bundle_identifiers = applications,
			type = "frontmost_application_if",
		} }
	end,
	application_unless = function(applications)
		if type(applications) == "string" then
			applications = { applications }
		end
		return { {
			bundle_identifiers = applications,
			type = "frontmost_application_unless",
		} }
	end,
}
karabiner.rule = {
	description = "auto generated by lua_keymapper",
	manipulators = {},
}
---@type table<integer,lua_keymapper.table>
karabiner.bindlist = {}
for i = 0, 31 do
	karabiner.bindlist[i] = {}
end

function karabiner.int2mods(mod)
	if type(mod) ~= "number" then
		return mod
	end
	local flag = nil
	local ret = {}
	for index, value in pairs(karabiner.modifier) do
		if mod & value ~= 0 then
			flag = true
			ret[#ret + 1] = index
		end
	end
	return flag and ret
end
function karabiner.int2vitualmods(mod)
	if not mod then
		return nil
	end
	local flag = nil
	local ret = {}
	for index, value in pairs(karabiner.vitualMod) do
		if mod & value ~= 0 then
			ret[#ret + 1] = index
			flag = true
		end
	end
	return flag and ret
end

--- Change Karabiner.to into Karabiner.json.to
---@param to Karabiner.to?
---@return Karabiner.json.to?
function karabiner.convert_to(to)
	if not to then
		return
	end
	if type(to) == "string" then
		if to == "fn" then
			return {
				apple_vendor_top_case_key_code = "keyboard_fn",
			}
		else
			return { key_code = to }
		end
	elseif getmetatable(to) == SHELL then
		return to:karabiner()
	else
		to[2] = karabiner.int2mods(to[2])
		if to[1] == "fn" then
			return {
				apple_vendor_top_case_key_code = "keyboard_fn",
				modifiers = to[2],
			}
		else
			return { key_code = to[1], modifiers = to[2] }
		end
	end
end
---@param key string|integer
---@param mod lua_keymapper.mod[]|integer
---@param fn string|table|SHELL
---@param priority integer?
---@param conditions table?
karabiner.bind = function(key, mod, fn, conditions, priority)
	local to = karabiner.convert_to(fn)
	mod = mod2int(mod)
	priority = priority or 100
	if not conditions then
		priority = 1
		conditions = karabiner.condition.not_moonlight()
	end
	if not karabiner.bindlist[mod][key] then
		karabiner.bindlist[mod][key] = {}
	end
	local i = 1
	while karabiner.bindlist[mod][key][i] do
		if karabiner.bindlist[mod][key][i].priority <= priority then
			break
		end
		i = i + 1
	end
	table.insert(karabiner.bindlist[mod][key], i, { to = to, conditions = conditions, priority = priority })
end

--- Create a vitual modifier with name `name` and key `key`.
---@param key string
---@param name string
---@param overload string|table|SHELL|nil if has any value, this modifier will be lazy, i.e., when press with other key, it will be mod; when pressed alone, it will trig `overload`
function karabiner.createmod(key, name, overload, conditions)
	if not conditions then
		conditions = karabiner.condition.not_moonlight()
	end
	if karabiner.modifier[name] then
		table.insert(karabiner.rule.manipulators, {
			from = {
				key_code = key,
			},
			to = {
				key_code = name ~= "fn" and "left_" .. name or nil,
				apple_vendor_top_case_key_code = name == "fn" and "keyboard_fn" or nil,
				lazy = overload and true,
			},
			to_if_alone = karabiner.convert_to(overload),
			conditions = conditions,
			type = "basic",
		})
		return karabiner.modifier[name]
	elseif karabiner.vitualMod[name] then
		table.insert(karabiner.rule.manipulators, {
			from = {
				key_code = key,
			},
			to = {
				set_variable = {
					name = "vitual_mod_" .. name,
					value = 1,
				},
			},
			to_after_key_up = {
				set_variable = {
					name = "vitual_mod_" .. name,
					value = 0,
				},
			},
			to_if_alone = karabiner.convert_to(overload),
			type = "basic",
		})
		return karabiner.vitualMod[name]
	else
		table.insert(karabiner.rule.manipulators, {
			from = {
				key_code = key,
			},
			to = {
				set_variable = {
					name = "vitual_mod_" .. name,
					value = 1,
				},
			},
			to_after_key_up = {
				set_variable = {
					name = "vitual_mod_" .. name,
					value = 0,
				},
			},
			to_if_alone = karabiner.convert_to(overload),
			type = "basic",
		})
		karabiner.vitualMod[name] = karabiner._next_vitual_mod_value
		karabiner._next_vitual_mod_value = karabiner._next_vitual_mod_value * 2
		for i = karabiner.vitualMod[name], karabiner._next_vitual_mod_value - 1 do
			karabiner.bindlist[i] = {}
		end
		return karabiner.vitualMod[name]
	end
end

function karabiner.tojson()
	for mod, mod_t in ipairs(karabiner.bindlist) do
		for key, key_t in pairs(mod_t) do
			for _, to in ipairs(key_t) do
				local vitualmods = karabiner.int2vitualmods(mod)
				if vitualmods then
					to.conditions = to.conditions or JSON.empty_array
					for _, vitualmod in ipairs(vitualmods) do
						table.insert(to.conditions, {
							name = "vitual_mod_" .. vitualmod,
							type = "variable_if",
							value = 1,
						})
					end
				end
				local phymods = karabiner.int2mods(mod)
				local modifiers = phymods and {
					mandatory = phymods,
				}
				local from
				if key == "fn" then
					from = { apple_vendor_top_case_key_code = "keyboard_fn", modifiers = modifiers }
				else
					from = {
						key_code = key,
						modifiers = modifiers,
					}
				end
				table.insert(karabiner.rule.manipulators, {
					from = from,
					to = to.to,
					to_if_alone = to.to_if_alone,
					to_after_key_up = to.to_after_key_up,
					conditions = to.conditions,
					type = "basic",
				})
			end
		end
	end
	return JSON.encode(karabiner.rule)
end
if arg[1] == "karabiner" then
	karabiner.createmod("caps_lock", "control", "escape")
	local ESC = karabiner.createmod("escape", "esc")
	local shottr_simp_shortcuts = {
		["1"] = "Capture Screen",
		["2"] = "Capture Area",
		["3"] = "Scrolling Capture",
		["9"] = "Recongize Text/QR",
	}
	local shottr_complex_shortcuts = {
		["4"] = "Scrolling (Up)",
		["5"] = "Capture Active Window",
		["6"] = "Capture Any Window",
		["7"] = "Delayed Screenshot (3S)",
		["8"] = "Repeat Area Capture",
	}
	for key, value in pairs(shottr_simp_shortcuts) do
		karabiner.bind(
			key,
			ESC,
			SHELL.new([=[osascript -e 'tell application "System Events" to tell process "Shottr"
        click menu item "]=] .. value .. [=[" of menu 1 of menu bar 2
    end tell'
    ]=])
		)
	end
	for key, value in pairs(shottr_complex_shortcuts) do
		karabiner.bind(
			key,
			ESC,
			SHELL.new([=[osascript -e 'tell application "System Events" to tell process "Shottr"
        click menu item "]=] .. value .. [=[" of menu "more" of menu item "more" of menu 1 of menu bar 2
    end tell'
  ]=])
		)
	end
	local function yabai_m(cmd)
		return SHELL.new("/opt/homebrew/bin/yabai -m " .. cmd)
	end
	local direction = {
		h = "west",
		l = "east",
		j = "south",
		k = "north",
		tab = "recent",
	}
	for key, dir in pairs(direction) do
		karabiner.bind(key, SUPER, yabai_m("window --focus " .. dir))
		karabiner.bind(key, SUPER + SHIFT, yabai_m("window --swap " .. dir))
	end
	for i = 1, 9 do
		karabiner.bind(
			tostring(i),
			SUPER,
			yabai_m("space --focus fullscreen" .. tostring(i)) | yabai_m("space --focus " .. tostring(i))
		)
		karabiner.bind(tostring(i), SUPER + SHIFT, yabai_m("window --space " .. tostring(i) .. " --focus"))
	end
	local yabai_maps = {
		-- { "f", SUPER, "window --toggle native-fullscreen" },
		{ "f", SUPER + SHIFT, "window --toggle zoom-fullscreen" },
		{ "r", SUPER + SHIFT, "space --rotate 90" },
		{ "r", SUPER, "window --toggle split" },
		{ "v", SUPER, "window --toggle float" },
		{ "p", SUPER, "window --toggle sticky" },
		{ "q", SUPER, "window --close" },
	}
	for _, map in ipairs(yabai_maps) do
		karabiner.bind(map[1], map[2], yabai_m(map[3]))
	end
	karabiner.bind(
		"f",
		SUPER,
		SHELL.new(
			"YABAI_CURRENT_SPACE=$(/opt/homebrew/bin/yabai -m query --spaces --space | jq '.index');YABAI_NEW_SPACE_INDEX=$(/opt/homebrew/bin/yabai -m query --spaces | jq 'length+1');  /opt/homebrew/bin/yabai -m window --toggle native-fullscreen; /opt/homebrew/bin/yabai -m space $YABAI_NEW_SPACE_INDEX --label fullscreen$YABAI_CURRENT_SPACE;  "
		)
	)
	local shortcuts = {
		b = "open -a zen.app",
		d = "open -a Eudic.app",
		t = "/Applications/kitty.app/Contents/MacOS/kitty --detach -1 -d '~'",
		q = "open -a QQ.app",
		s = "open -a sioyek.app",
		w = "open -a WeChat.app",
		spacebar = "open -a 'Alfred 5.app'",
	}
	for key, cmd in pairs(shortcuts) do
		karabiner.bind(key, ALT, SHELL.new(cmd))
	end
	karabiner.bind("p", FN + CTRL, SHELL.new("$HOME/.local/bin/toggle_proxy"))
	print(karabiner.tojson())
end
return M
