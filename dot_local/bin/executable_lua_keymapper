#!/usr/bin/env lua
local karabiner = {}
local keyd = {}
local aerospace = {}
local hyprland = {}
local M = { karabiner = karabiner, keyd = keyd, aerospace = aerospace, hyprland = hyprland }
-- SHIFT CAPS CTRL/CONTROL ALT MOD2 MOD3 SUPER/WIN/LOGO/MOD4 MOD5
---@alias lua_keymapper.mod "SHIFT"|"CTRL"|"ALT"|"SUPER"
---@class lua_keymapper.processor
---@field fn function
---@field condition fun():boolean
---@field priority number
---@class lua_keymapper.table
---@field [string] lua_keymapper.processor[]

M.modifier = {
	SHIFT = 1,
	CTRL = 2,
	ALT = 4,
	SUPER = 8,
	FN = 16,
}
local SHIFT = 1
local CTRL = 2
local ALT = 4
local SUPER = 8
local FN = 16

local function mod2int(mods)
	if not mods then
		return 0
	end
	if type(mods) == "number" then
		return mods
	end
	local ret = 0
	if type(mods) == "string" then
		mods = { mods }
	end
	for index, value in ipairs(mods) do
		local mod = M.modifier[value]
		if not mod then
			error("unknown modifier: " .. value)
			break
		end
		ret = ret + mod
	end
	return ret
end
--For karabiner
karabiner.modifier = {
	shift = 1,
	control = 2,
	command = 4,
	option = 8,
	fn = 16,
}

local JSON = require("cjson")
karabiner.condition = {
	always = function()
		return JSON.empty_array
	end,
	application = function(applications)
		if type(applications) == "string" then
			applications = { applications }
		end
		return { {
			bundle_identifiers = applications,
			type = "frontmost_application_if",
		} }
	end,
	application_unless = function(applications)
		if type(applications) == "string" then
			applications = { applications }
		end
		return { {
			bundle_identifiers = applications,
			type = "frontmost_application_unless",
		} }
	end,
}
karabiner.rule = {
	description = "auto generated by lua_keymapper",
	manipulators = {},
}
---@type table<integer,lua_keymapper.table>
karabiner.bindlist = {}
for i = 0, 31 do
	karabiner.bindlist[i] = {}
end

function karabiner.int2mods(mod)
	if not mod then
		return nil
	end
	local ret = {}
	for index, value in pairs(karabiner.modifier) do
		if mod & value ~= 0 then
			ret[#ret + 1] = index
		end
	end
	return ret
end
karabiner._shell = {}
karabiner.shell = function(cmd)
	return { karabiner._shell, cmd }
end
---@param key string|integer
---@param mod lua_keymapper.mod[]|integer
---@param fn string|table
---@param priority integer?
---@param conditions table?
karabiner.bind = function(key, mod, fn, conditions, priority)
	local to
	if type(fn) == "string" then
		to = { keycode = fn }
	elseif fn[1] == karabiner._shell then
		to = { shell_command = fn[2] }
	else
		to = { keycode = fn[1], modifiers = fn[2] }
	end
	mod = mod2int(mod)
	priority = priority or 100
	if not conditions then
		priority = 1
		conditions = karabiner.condition.always()
	end
	if not karabiner.bindlist[mod][key] then
		karabiner.bindlist[mod][key] = {}
	end
	local i = 1
	while karabiner.bindlist[mod][key][i] do
		if karabiner.bindlist[mod][key][i].priority <= priority then
			break
		end
		i = i + 1
	end
	table.insert(karabiner.bindlist[mod][key], i, { to = to, conditions = conditions, priority = priority })
end
function karabiner.tojson()
	for mod, mod_t in ipairs(karabiner.bindlist) do
		for key, key_t in pairs(mod_t) do
			for _, to in ipairs(key_t) do
				table.insert(karabiner.rule.manipulators, {
					from = {
						key_code = key,
						modifiers = {
							mandatory = karabiner.int2mods(mod),
						},
					},
					to = to.to,
					conditions = to.conditions,
					type = "basic",
				})
			end
		end
	end
	return JSON.encode(karabiner.rule)
end
if arg[1] == "karabiner" then
	local function yabai_m(cmd)
		return karabiner.shell("/opt/homebrew/bin/yabai -m " .. cmd)
	end
	local direction = {
		h = "west",
		l = "east",
		j = "south",
		k = "north",
		tab = "recent",
	}
	for key, dir in pairs(direction) do
		karabiner.bind(key, SUPER, yabai_m("window --focus " .. dir))
		karabiner.bind(key, SUPER + SHIFT, yabai_m("window --swap " .. dir))
	end
	for i = 1, 9 do
		karabiner.bind(tostring(i), SUPER, yabai_m("space --focus " .. tostring(i)))
		karabiner.bind(tostring(i), SUPER + SHIFT, yabai_m("window --space " .. tostring(i) .. " --focus"))
	end
	local yabai_maps = {
		{ "f", SUPER, "window --toggle native-fullscreen" },
		{ "f", SUPER + SHIFT, "window --toggle zoom-fullscreen" },
		{ "r", SUPER + SHIFT, "space --rotate 90" },
		{ "r", SUPER, "window --toggle split" },
		{ "v", SUPER, "window --toggle float" },
		{ "p", SUPER, "window --toggle sticky" },
	}
	for _, map in ipairs(yabai_maps) do
		karabiner.bind(map[1], map[2], yabai_m(map[3]))
	end
	print(karabiner.tojson())
end
return M
