#!/usr/bin/env bash
# echo "${SUNSHINE_CLIENT_WIDTH},${SUNSHINE_CLIENT_HEIGHT},${SUNSHINE_CLIENT_FPS}" > /home/dirichy/sunshine.log
case "$1" in
  expand)
    hyprctl eval "hl.sunshine.only_then_expand(${SUNSHINE_CLIENT_WIDTH},${SUNSHINE_CLIENT_HEIGHT},${SUNSHINE_CLIENT_FPS})"
    sleep 5
    ;;
  only)
    hyprctl eval "hl.sunshine.only(${SUNSHINE_CLIENT_WIDTH},${SUNSHINE_CLIENT_HEIGHT},${SUNSHINE_CLIENT_FPS})"
    sleep 5
    ;;
  reset)
    hyprctl output remove SUNSHINE
    hyprctl reload
    ;;
esac
exit 0
