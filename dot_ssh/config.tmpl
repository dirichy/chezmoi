{{- $routerIp := "unknownRouterIp" -}}
{{- if eq .chezmoi.os "linux" -}}
{{- $routerIp = "linuxRouterIP" -}}
{{- else if eq .chezmoi.os "darwin" -}}
{{ $routerIp = "darwinRouterIP" -}}
{{- end -}}


Host server
  Hostname {{secret "serverIP" "0.0.0.0"}}
  Port 22
  User root

Match host dell exec "{{includeTemplate $routerIp "24:5a:5f:78:33:fa"}}"
  Hostname 192.168.1.66
  Port 22
Host dell
  Hostname {{secret "serverIP" "0.0.0.0"}}
  Port 520
  User dirichy

Match host wyy exec "{{includeTemplate $routerIp "a4:ba:70:8:bc:3d"}}"
  Hostname 192.168.1.66
  Port 22
Host wyy
  Hostname {{secret "serverIP" "0.0.0.0"}}
  Port 1314
  User eva

Match host byl exec "{{includeTemplate $routerIp "24:5a:5f:78:33:fa"}}"
  Hostname 192.168.1.88
  Port 22
  ProxyJump none
Host byl
  Hostname 192.168.1.88
  Port 22
  User dirichy
  ProxyJump dell
