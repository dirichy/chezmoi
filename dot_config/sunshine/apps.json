{
  "apps": [
    {
      "auto-detach": true,
      "exclude-global-prep-cmd": false,
      "exit-timeout": 5,
      "image-path": "desktop.png",
      "name": "Desktop",
      "prep-cmd": [],
      "wait-all": true
    },
    {
      "auto-detach": true,
      "cmd": [],
      "elevated": false,
      "exclude-global-prep-cmd": false,
      "exit-timeout": 5,
      "image-path": "",
      "name": "ipad/only",
      "prep-cmd": [
        {
          "do": "hyprlua hypr.sunshine.only(\"ipad\")",
          "undo": "hyprlua hypr.sunshine.reset()"
        }
      ],
      "wait-all": true
    },
    {
      "auto-detach": true,
      "cmd": [],
      "elevated": false,
      "exclude-global-prep-cmd": false,
      "exit-timeout": 5,
      "image-path": "",
      "name": "ipad/expand",
      "prep-cmd": [
        {
          "do": "hyprlua hypr.sunshine.expand(\"ipad\")",
          "undo": "hyprlua hypr.sunshine.reset()"
        }
      ],
      "wait-all": true
    },
    {
      "auto-detach": true,
      "cmd": [],
      "elevated": false,
      "exclude-global-prep-cmd": false,
      "exit-timeout": 5,
      "image-path": "",
      "name": "mac/only",
      "prep-cmd": [
        {
          "do": "hyprlua hypr.sunshine.only(\"macbook\")",
          "undo": "hyprlua hypr.sunshine.reset()"
        }
      ],
      "wait-all": true
    },
    {
      "auto-detach": true,
      "cmd": [],
      "elevated": false,
      "exclude-global-prep-cmd": false,
      "exit-timeout": 5,
      "image-path": "",
      "name": "mac/expand",
      "prep-cmd": [
        {
          "do": "hyprlua hypr.sunshine.expand(\"macbook\")",
          "undo": "hyprlua hypr.sunshine.reset()"
        }
      ],
      "wait-all": true
    }
  ],
  "env": {
    "PATH": "$(PATH):$(HOME)/.local/bin"
  }
}
