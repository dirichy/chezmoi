{{- if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# font
paru -S --needed noto-fonts-cjk
# rime
paru -S --needed fcitx5-rime fcitx5 fcitx5-configtool
# audio
paru -S --needed pipewire-audio pipewire-pulse wireplumber bluez bluez-utils blueman
sudo systemctl enable --now bluetooth
# util
paru -S --needed keyd chezmoi openssh autossh greetd github-cli wl-clipboard fuse
sudo systemctl enable --now sshd greetd keyd
# util_network
paru -S --needed mihomo tailscale networkmanager
sudo systemctl enable --now NetworkManager
# util_gui
paru -S --needed kitty mpv zen-browser-bin wofi xorg-xrdb zathura sioyek-git zenity
# util_cli
paru -S --needed ffmpeg-full git gopass gopass-jsonapi fzf zoxide thefuck ripgrep tree-sitter-cli unzip tar wget curl zsh uv tmux luarocks lua luajit imagemagick lsd fd
# language
paru -S --needed go ruby php julia cargo lua luajit lua51
# util_tui
paru -S --needed neovim vim yazi lazygit bottom
# desktop
paru -S --needed hyprland hyprpaper waybar hypridle udisken sunshine socat ddcutil xdg-desktop-portal xdg-desktop-portal-gtk xdg-desktop-portal-hyprland xwaylandvideobridge
sudo luarocks --lua-version=5.1 install luasocket
sudo luarocks --lua-version=5.1 install lua-cjson 
sudo luarocks --lua-version=5.1 install luv
systemctl --user start hyprpaper waybar hypridle udisken sunshine
# latex
paru -S --needed texlive
{{- end -}}
